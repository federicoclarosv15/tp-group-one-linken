# Copiar a .env.local — NUNCA commitear .env.local
# WalletConnect Project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Anvil local (desarrollo) ──────────────────────────────────
# Correr: anvil en una terminal aparte
# Luego deployar: forge script script/DeployAll.s.sol --rpc-url http://127.0.0.1:8545 --broadcast
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# ── Sepolia (producción) ──────────────────────────────────────
